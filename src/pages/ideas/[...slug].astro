---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const ideas = await getCollection('ideas');
  return ideas.map(idea => ({
    params: { slug: idea.id },
    props: { idea },
  }));
}

const { idea } = Astro.props;
const { Content } = await render(idea);
---

<Base title={idea.data.title}>
  <style>
    h1 {
      font-size: 1.75rem;
      font-weight: normal;
      margin: 0 0 1rem;
      line-height: 1.3;
    }

    .meta {
      font-size: 0.85rem;
      color: var(--muted);
      font-family: var(--font-mono);
      margin-bottom: 2.5rem;
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .status {
      padding: 0.15rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: 2px;
      font-size: 0.75rem;
    }

    /* reuse blog prose styles */
    .prose :global(h2) { font-size: 1.25rem; font-weight: normal; margin-top: 2.5rem; }
    .prose :global(h3) { font-size: 1rem; margin-top: 2rem; }
    .prose :global(a) { color: inherit; }
    .prose :global(code) {
      font-family: var(--font-mono);
      font-size: 0.875em;
      background: #f5f5f5;
      padding: 0.1em 0.3em;
      border-radius: 2px;
    }
    .prose :global(pre) {
      background: #f5f5f5;
      padding: 1rem 1.25rem;
      overflow-x: auto;
      border-radius: 4px;
      font-size: 0.875rem;
    }
    .prose :global(pre code) { background: none; padding: 0; }
    .prose :global(blockquote) {
      border-left: 3px solid var(--border);
      margin-left: 0;
      padding-left: 1.25rem;
      color: var(--muted);
      font-style: italic;
    }

    .back {
      margin-top: 3rem;
      font-size: 0.85rem;
    }

    .back a {
      color: var(--muted);
      text-decoration: none;
    }

    .back a:hover { color: var(--text); }
  </style>

  <h1>{idea.data.title}</h1>

  <div class="meta">
    <span>{idea.data.date.toISOString().slice(0, 10)}</span>
    <span class="status">{idea.data.status}</span>
  </div>

  <article class="prose">
    <Content />
  </article>

  <div class="back"><a href="/ideas">← all ideas</a></div>
</Base>

---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const ideas = (await getCollection('ideas'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const byStatus = {
  mature: ideas.filter(i => i.data.status === 'mature'),
  growing: ideas.filter(i => i.data.status === 'growing'),
  seedling: ideas.filter(i => i.data.status === 'seedling'),
};
---

<Base title="ideas">
  <style>
    h1 {
      font-size: 1.25rem;
      font-weight: normal;
      margin: 0 0 0.5rem;
    }

    .description {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 2.5rem;
    }

    .group { margin-bottom: 2.5rem; }

    .group-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin: 0 0 0.75rem;
    }

    .idea-list { list-style: none; padding: 0; margin: 0; }

    .idea-list li {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--border);
    }

    .idea-list li:first-child { border-top: 1px solid var(--border); }

    .idea-list a { text-decoration: none; }
    .idea-list a:hover { text-decoration: underline; }

    .date {
      font-size: 0.8rem;
      color: var(--muted);
      white-space: nowrap;
      font-family: var(--font-mono);
    }

    .empty {
      color: var(--muted);
      font-style: italic;
    }
  </style>

  <h1>ideas</h1>
  <p class="description">rough thoughts, things being explored, and more developed concepts.</p>

  {Object.entries(byStatus).map(([status, group]) => group.length > 0 && (
    <div class="group">
      <p class="group-label">{status}</p>
      <ul class="idea-list">
        {group.map(idea => (
          <li>
            <a href={`/ideas/${idea.id}`}>{idea.data.title}</a>
            <span class="date">{idea.data.date.toISOString().slice(0, 10)}</span>
          </li>
        ))}
      </ul>
    </div>
  ))}

  {ideas.length === 0 && <p class="empty">nothing here yet.</p>}
</Base>

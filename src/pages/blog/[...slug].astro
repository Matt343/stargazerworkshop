---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.description}>
  <style>
    .meta {
      font-size: 0.85rem;
      color: var(--muted);
      font-family: var(--font-mono);
      margin-bottom: 2.5rem;
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .tag {
      font-size: 0.75rem;
      padding: 0.15rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: 2px;
    }

    h1 {
      font-size: 1.75rem;
      font-weight: normal;
      margin: 0 0 1rem;
      line-height: 1.3;
    }

    /* prose styles */
    .prose :global(h2) { font-size: 1.25rem; font-weight: normal; margin-top: 2.5rem; }
    .prose :global(h3) { font-size: 1rem; margin-top: 2rem; }
    .prose :global(a) { color: inherit; }
    .prose :global(code) {
      font-family: var(--font-mono);
      font-size: 0.875em;
      background: #f5f5f5;
      padding: 0.1em 0.3em;
      border-radius: 2px;
    }
    .prose :global(pre) {
      background: #f5f5f5;
      padding: 1rem 1.25rem;
      overflow-x: auto;
      border-radius: 4px;
      font-size: 0.875rem;
    }
    .prose :global(pre code) { background: none; padding: 0; }
    .prose :global(blockquote) {
      border-left: 3px solid var(--border);
      margin-left: 0;
      padding-left: 1.25rem;
      color: var(--muted);
      font-style: italic;
    }
    .prose :global(img) { max-width: 100%; height: auto; }

    .back {
      margin-top: 3rem;
      font-size: 0.85rem;
    }

    .back a {
      color: var(--muted);
      text-decoration: none;
    }

    .back a:hover { color: var(--text); }
  </style>

  <h1>{post.data.title}</h1>

  <div class="meta">
    <span>{post.data.date.toISOString().slice(0, 10)}</span>
    {post.data.tags.length > 0 && (
      <div class="tags">
        {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
  </div>

  <article class="prose">
    <Content />
  </article>

  <div class="back"><a href="/blog">← all posts</a></div>
</Base>

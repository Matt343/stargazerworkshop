---
import Base from '../../layouts/Base.astro';
import Update from '../../components/Update.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const updates = await getCollection('updates');
  const tracks = await getCollection('tracks');
  const trackName = new Map(tracks.map((t) => [t.id, t.data.name]));

  return posts.map((post) => ({
    params: { id: post.id },
    props: {
      post,
      updates: updates
        .filter((u) => u.data.post === post.id)
        .sort((a, b) => a.data.order - b.data.order),
      trackName,
    },
  }));
}

const { post, updates, trackName } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title}>
  <style>
    h1 {
      font-size: 1.75rem;
      font-weight: normal;
      margin: 0 0 0.75rem;
      line-height: 1.3;
    }

    .meta {
      font-size: 0.85rem;
      color: var(--muted);
      font-family: var(--font-mono);
      margin-bottom: 2rem;
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .tag {
      font-size: 0.75rem;
      padding: 0.15rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: 2px;
    }

    /* intro prose */
    .intro :global(a) {
      color: inherit;
    }
    .intro :global(code) {
      font-family: var(--font-mono);
      font-size: 0.875em;
      background: #f5f5f5;
      padding: 0.1em 0.3em;
      border-radius: 2px;
    }

    .updates-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin: 3rem 0 0;
    }

    .back {
      margin-top: 3rem;
      font-size: 0.85rem;
    }
    .back a {
      color: var(--muted);
      text-decoration: none;
    }
    .back a:hover {
      color: var(--text);
    }
  </style>

  <h1>{post.data.title}</h1>
  <div class="meta">
    <span>{post.data.date.toISOString().slice(0, 10)}</span>
    {
      post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )
    }
  </div>

  <article class="intro"><Content /></article>

  {
    updates.length > 0 && (
      <>
        <p class="updates-label">updates</p>
        {updates.map((update) => (
          <Update update={update} context="post" trackName={trackName.get(update.data.track)} />
        ))}
      </>
    )
  }

  <div class="back"><a href="/posts">← all posts</a></div>
</Base>

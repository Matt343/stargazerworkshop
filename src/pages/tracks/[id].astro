---
import Base from '../../layouts/Base.astro';
import Update from '../../components/Update.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tracks = await getCollection('tracks');
  const updates = await getCollection('updates');

  return tracks.map((track) => ({
    params: { id: track.id },
    props: {
      track,
      // Track story in isolation: newest update first.
      updates: updates
        .filter((u) => u.data.track === track.id)
        .sort(
          (a, b) => b.data.date.valueOf() - a.data.date.valueOf() || b.data.order - a.data.order,
        ),
    },
  }));
}

const { track, updates } = Astro.props;
---

<Base title={track.data.name} description={track.data.blurb}>
  <style>
    h1 {
      font-size: 1.75rem;
      font-weight: normal;
      margin: 0 0 0.75rem;
      line-height: 1.3;
    }

    .meta {
      font-size: 0.85rem;
      color: var(--muted);
      font-family: var(--font-mono);
      margin-bottom: 1rem;
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .status {
      padding: 0.15rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: 2px;
      font-size: 0.75rem;
    }

    .blurb {
      color: var(--muted);
      margin: 0 0 2.5rem;
    }

    .empty {
      color: var(--muted);
      font-style: italic;
      margin-top: 2rem;
    }

    .back {
      margin-top: 3rem;
      font-size: 0.85rem;
    }
    .back a {
      color: var(--muted);
      text-decoration: none;
    }
    .back a:hover {
      color: var(--text);
    }
  </style>

  <h1>{track.data.name}</h1>
  <div class="meta">
    <span class="status">{track.data.status}</span>
    {track.data.started && <span>since {track.data.started.toISOString().slice(0, 10)}</span>}
    <span>{updates.length} {updates.length === 1 ? 'update' : 'updates'}</span>
  </div>

  {track.data.blurb && <p class="blurb">{track.data.blurb}</p>}

  {
    updates.length > 0 ? (
      updates.map((update) => <Update update={update} context="track" />)
    ) : (
      <p class="empty">no updates yet — this track is still just an idea.</p>
    )
  }

  <div class="back"><a href="/tracks">← all tracks</a></div>
</Base>

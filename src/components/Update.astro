---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
  update: CollectionEntry<'updates'>;
  // Where to show the cross-link: on a post we link to the track,
  // on a track timeline we link to the originating post.
  context: 'post' | 'track';
  // Display name for the linked track (post context only).
  trackName?: string;
}

const { update, context, trackName } = Astro.props;
const { Content } = await render(update);
const dateStr = update.data.date.toISOString().slice(0, 10);
---

<section class="update">
  <header class="update-head">
    <h3 class="update-title">{update.data.title}</h3>
    {context === 'post' ? (
      <a class="update-link" href={`/tracks/${update.data.track}`}>{trackName ?? update.data.track} →</a>
    ) : (
      <a class="update-link" href={`/posts/${update.data.post}`}>{dateStr} →</a>
    )}
  </header>
  <div class="prose">
    <Content />
  </div>
</section>

<style>
  .update {
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }

  .update-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .update-title {
    font-size: 1.1rem;
    font-weight: normal;
    margin: 0;
  }

  .update-link {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    white-space: nowrap;
    font-family: var(--font-mono);
  }

  .update-link:hover { color: var(--text); opacity: 1; }

  .prose :global(h4) { font-size: 1rem; margin: 1.5rem 0 0.5rem; }
  .prose :global(a) { color: inherit; }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: #f5f5f5;
    padding: 0.1em 0.3em;
    border-radius: 2px;
  }
  /* Shiki emits inline styles + its own background on pre.astro-code */
  .prose :global(pre) {
    padding: 1rem 1.25rem;
    overflow-x: auto;
    border-radius: 4px;
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .prose :global(pre code) { background: none; padding: 0; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--border);
    margin-left: 0;
    padding-left: 1.25rem;
    color: var(--muted);
    font-style: italic;
  }
  .prose :global(img) { max-width: 100%; height: auto; }
</style>
